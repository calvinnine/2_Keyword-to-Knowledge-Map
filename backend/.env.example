# Application
APP_ENV=development
APP_SECRET_KEY=changeme

# Database
DATABASE_URL=postgresql+psycopg2://k2km:k2km@localhost:5432/k2km
DATABASE_URL_ASYNC=postgresql+asyncpg://k2km:k2km@localhost:5432/k2km

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OpenAlex
OPENALEX_EMAIL=your-email@example.com
OPENALEX_API_KEY=

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=

# Groq (Phase 5 insight generation — leave blank to skip)
# Get a free key at https://console.groq.com
GROQ_API_KEY=
INSIGHT_MODEL=llama3-70b-8192
INSIGHT_BASE_URL=https://api.groq.com/openai/v1

# NTIS (Phase 6 — leave blank until API key is issued)
NTIS_API_KEY=

# Job limits
JOB_DEFAULT_MAX_PAPERS=20000
JOB_ABSOLUTE_MAX_PAPERS=50000
